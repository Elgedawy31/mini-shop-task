{
  "name": "mini-shop-task",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "bunx concurrently -n dashboard,backend -c cyan,green \"bun --cwd dashboard dev\" \"bun --cwd backend dev\"",
    "dev:dashboard": "bun --cwd dashboard dev",
    "dev:backend": "bun --cwd backend dev",
    "build": "bun run build:dashboard && bun run build:backend",
    "build:dashboard": "bun --cwd dashboard build",
    "build:backend": "bun --cwd backend build",
    "lint": "bunx eslint .",
    "format": "bunx prettier --write \"**/*.{js,jsx,ts,tsx,json,md,css,html,yml,yaml}\"",
    "format:check": "bunx prettier --check \"**/*.{js,jsx,ts,tsx,json,md,css,html,yml,yaml}\""
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,json,md,css,html,yml,yaml}": [
      "bunx prettier --write"
    ]
  }
}
