# =============================================================================
# Mini Shop — Backend environment template
# =============================================================================
#
# SETUP
#   1. cp .env.example .env
#   2. Open Supabase Dashboard → Project Settings → API
#   3. Paste YOUR project URL, anon key, and service_role key into .env only
#   4. Create Storage bucket: product-images (public)
#   5. bun run db:link && bun run db:push && bun run seed
#
# SECURITY: Do not put real keys in this file. Only placeholders belong in git.
#           Real credentials live in backend/.env (gitignored).
#
# TEST DATA (after seed — see root README "Test accounts")
#   Customer: customer@minishop.test / Customer123!
#   Admin:    admin@minishop.test    / Admin12345!
# =============================================================================

PORT=5001
HOST=0.0.0.0
NODE_ENV=development

# Comma-separated origins (dashboard + Expo). Add your LAN IP for physical devices:
# http://192.168.x.x:8081
CORS_ORIGIN=http://localhost:5000,http://localhost:8081,http://127.0.0.1:8081

# Supabase → Project Settings → API
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

STORAGE_BUCKET=product-images

# Optional — Database → Connection string (SQL tools only; not required for the API)
# DATABASE_URL=postgresql://postgres.[ref]:[YOUR-PASSWORD]@aws-0-[region].pooler.supabase.com:5432/postgres
