# =============================================================================
# Mini Shop — Mobile environment template
# =============================================================================
#
# SETUP
#   1. Backend must be running on port 5001 (see backend/.env.example)
#   2. Usually no .env needed — Expo auto-detects your PC IP in development
#   3. If needed: cp .env.example .env and set EXPO_PUBLIC_API_BASE_URL below
#
# TEST CUSTOMER (after backend seed — see root README)
#   customer@minishop.test / Customer123!
# =============================================================================

# Physical device on same Wi‑Fi (replace with your computer's LAN IP):
# EXPO_PUBLIC_API_BASE_URL=http://192.168.1.71:5001
