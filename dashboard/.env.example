# Dashboard — copy to .env.development (or .env.local) for local overrides.
# Vite loads .env.development automatically in `bun dev`.

# Fastify API (required in production builds; default works for local dev)
VITE_API_BASE_URL=http://localhost:5001

# Optional: Supabase Realtime on the Orders page (live queue updates).
# Use the same URL and anon key as backend/.env — safe to expose in the browser.
# VITE_SUPABASE_URL=https://your-project-ref.supabase.co
# VITE_SUPABASE_ANON_KEY=your-anon-key
